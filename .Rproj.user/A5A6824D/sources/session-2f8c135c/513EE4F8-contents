if (requireNamespace("compiler", quietly = TRUE)) {
  .smgp_kalman_smoother <- compiler::cmpfun(
    .smgp_kalman_smoother)
  .smgp_binary_forward_backward <- compiler::cmpfun(
    .smgp_binary_forward_backward)
  .smgp_expected_gp_prior <- compiler::cmpfun(
    .smgp_expected_gp_prior)
  .smgp_gp_prior_sufficient <- compiler::cmpfun(
    .smgp_gp_prior_sufficient)
  .smgp_positive_gaussian_update <- compiler::cmpfun(
    .smgp_positive_gaussian_update)
}
