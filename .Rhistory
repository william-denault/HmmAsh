source("C:/Users/willi/Downloads/ash_hmm_native_learned_means_bundle/HmmAsh.R", echo = TRUE)
source("C:/Users/willi/AppData/Local/Temp/359f8f98-7d25-4b0b-9e2f-9fd3d61e158c_ash_hmm_native_learned_means_bundle.zip.58c/utils.R", echo = TRUE)
# Example using the Donoho--Johnstone signals from wavethresh.
# This implementation is dependency-free; wavethresh is used only to obtain the
# example signals.
stopifnot(requireNamespace("wavethresh", quietly = TRUE))
set.seed(1)
signals <- wavethresh::DJ.EX()
blocks <- signals$blocks
bumps <- signals$bumps
noisy_blocks <- blocks + rnorm(length(blocks))
noisy_bumps <- bumps + rnorm(length(bumps))
se <- rep(1, length(blocks))
# Direct nonzero-to-nonzero changes occur in blocks, so use the full transition
# graph. The dense grid, center learning and pruning are all automatic.
fit_blocks <- fit_ash_hmm(
noisy_blocks, se,
half_grid = 35L,
grid_shape = 2,
topology = "full",
fixed_pointmass_states = 1L,
mean_min_self_transition = 0.93,
prune_max_loglik_loss = 0.1,
maxiter = 50L,
verbose = TRUE)
# Bumps are smooth rather than piecewise constant. A higher persistence
# threshold prevents short curved portions from being treated as plateaus.
fit_bumps <- fit_ash_hmm(
noisy_bumps, se,
half_grid = 35L,
grid_shape = 2,
topology = "full",
fixed_pointmass_states = 1L,
mean_min_self_transition = 0.97,
maxiter = 50L,
verbose = TRUE)
# Fixed-grid reference using exactly the old learning behavior.
fit_blocks_fixed <- fit_ash_hmm(
noisy_blocks, se,
half_grid = 35L,
grid_shape = 2,
topology = "full",
fixed_pointmass_states = 1L,
learn_state_means = FALSE,
prune_states = FALSE,
maxiter = 50L)
op <- par(mfrow = c(2, 1), mar = c(3, 4, 2, 1))
on.exit(par(op), add = TRUE)
plot(fit_blocks$posterior$mean, type = "l", lwd = 2,
main = "Blocks: learned centers and dynamic pruning",
xlab = "index", ylab = "effect")
lines(blocks, col = "forestgreen", lwd = 1.5)
lines(fit_blocks_fixed$posterior$mean, col = "steelblue", lty = 2)
legend("topright", c("learned centers", "truth", "fixed grid"),
col = c("black", "forestgreen", "steelblue"),
lty = c(1, 1, 2), bty = "n")
plot(fit_bumps$posterior$mean, type = "l", lwd = 2,
main = "Bumps: conservative center learning",
xlab = "index", ylab = "effect")
lines(bumps, col = "forestgreen", lwd = 1.5)
cat("blocks learned-center MSE:",
mean((fit_blocks$posterior$mean - blocks)^2), "\n")
cat("blocks fixed-grid MSE:",
mean((fit_blocks_fixed$posterior$mean - blocks)^2), "\n")
cat("blocks states:", length(fit_blocks$grid$initial_selected_mu), "->",
length(fit_blocks$fitted$mu), "\n")
cat("bumps MSE:", mean((fit_bumps$posterior$mean - bumps)^2), "\n")
cat("implementation:", ash_hmm_version(), "\n")
op <- par(mfrow = c(1, 1) )
on.exit(par(op), add = TRUE)
plot(fit_blocks$posterior$mean, type = "l", lwd = 2,
main = "Blocks: learned centers and dynamic pruning",
xlab = "index", ylab = "effect")
lines(blocks, col = "forestgreen", lwd = 1.5)
lines(fit_blocks_fixed$posterior$mean, col = "steelblue", lty = 2)
legend("topright", c("learned centers", "truth", "fixed grid"),
col = c("black", "forestgreen", "steelblue"),
lty = c(1, 1, 2), bty = "n")
plot(fit_bumps$posterior$mean, type = "l", lwd = 2,
main = "Bumps: conservative center learning",
xlab = "index", ylab = "effect")
lines(bumps, col = "forestgreen", lwd = 1.5)
cat("blocks learned-center MSE:",
mean((fit_blocks$posterior$mean - blocks)^2), "\n")
cat("blocks fixed-grid MSE:",
mean((fit_blocks_fixed$posterior$mean - blocks)^2), "\n")
cat("blocks states:", length(fit_blocks$grid$initial_selected_mu), "->",
length(fit_blocks$fitted$mu), "\n")
cat("bumps MSE:", mean((fit_bumps$posterior$mean - bumps)^2), "\n")
cat("implementation:", ash_hmm_version(), "\n")
# Example using the Donoho--Johnstone signals from wavethresh.
# This implementation is dependency-free; wavethresh is used only to obtain the
# example signals.
stopifnot(requireNamespace("wavethresh", quietly = TRUE))
set.seed(1)
signals <- wavethresh::DJ.EX()
blocks <- signals$blocks
bumps <- signals$bumps
noisy_blocks <- blocks + rnorm(length(blocks))
noisy_bumps <- bumps + rnorm(length(bumps))
se <- rep(1, length(blocks))
# Direct nonzero-to-nonzero changes occur in blocks, so use the full transition
# graph. The dense grid, center learning and pruning are all automatic.
fit_blocks <- fit_ash_hmm(
noisy_blocks, se,
half_grid = 35L,
grid_shape = 2,
topology = "hub",
fixed_pointmass_states = 1L,
mean_min_self_transition = 0.93,
prune_max_loglik_loss = 0.1,
maxiter = 50L,
verbose = TRUE)
# Bumps are smooth rather than piecewise constant. A higher persistence
# threshold prevents short curved portions from being treated as plateaus.
fit_bumps <- fit_ash_hmm(
noisy_bumps, se,
half_grid = 35L,
grid_shape = 2,
topology = "hub",
fixed_pointmass_states = 1L,
mean_min_self_transition = 0.97,
maxiter = 50L,
verbose = TRUE)
# Fixed-grid reference using exactly the old learning behavior.
fit_blocks_fixed <- fit_ash_hmm(
noisy_blocks, se,
half_grid = 35L,
grid_shape = 2,
topology = "hub",
fixed_pointmass_states = 1L,
learn_state_means = FALSE,
prune_states = FALSE,
maxiter = 50L)
op <- par(mfrow = c(1, 1) )
on.exit(par(op), add = TRUE)
plot(fit_blocks$posterior$mean, type = "l", lwd = 2,
main = "Blocks: learned centers and dynamic pruning",
xlab = "index", ylab = "effect")
lines(blocks, col = "forestgreen", lwd = 1.5)
lines(fit_blocks_fixed$posterior$mean, col = "steelblue", lty = 2)
legend("topright", c("learned centers", "truth", "fixed grid"),
col = c("black", "forestgreen", "steelblue"),
lty = c(1, 1, 2), bty = "n")
plot(fit_bumps$posterior$mean, type = "l", lwd = 2,
main = "Bumps: conservative center learning",
xlab = "index", ylab = "effect")
lines(bumps, col = "forestgreen", lwd = 1.5)
cat("blocks learned-center MSE:",
mean((fit_blocks$posterior$mean - blocks)^2), "\n")
cat("blocks fixed-grid MSE:",
mean((fit_blocks_fixed$posterior$mean - blocks)^2), "\n")
cat("blocks states:", length(fit_blocks$grid$initial_selected_mu), "->",
length(fit_blocks$fitted$mu), "\n")
cat("bumps MSE:", mean((fit_bumps$posterior$mean - bumps)^2), "\n")
cat("implementation:", ash_hmm_version(), "\n")
plot(fit_blocks$posterior$mean, type = "l", lwd = 2,
main = "Blocks: learned centers and dynamic pruning",
xlab = "index", ylab = "effect")
lines(blocks, col = "forestgreen", lwd = 1.5)
lines(fit_blocks_fixed$posterior$mean, col = "steelblue", lty = 2)
legend("topright", c("learned centers", "truth", "fixed grid"),
col = c("black", "forestgreen", "steelblue"),
lty = c(1, 1, 2), bty = "n")
plot(fit_bumps$posterior$mean, type = "l", lwd = 2,
main = "Bumps: conservative center learning",
xlab = "index", ylab = "effect")
lines(bumps, col = "forestgreen", lwd = 1.5)
cat("blocks learned-center MSE:",
mean((fit_blocks$posterior$mean - blocks)^2), "\n")
cat("blocks fixed-grid MSE:",
mean((fit_blocks_fixed$posterior$mean - blocks)^2), "\n")
cat("blocks states:", length(fit_blocks$grid$initial_selected_mu), "->",
length(fit_blocks$fitted$mu), "\n")
cat("bumps MSE:", mean((fit_bumps$posterior$mean - bumps)^2), "\n")
cat("implementation:", ash_hmm_version(), "\n")
library(wavethresh)
library(HmmAsh)
set.seed(1)
blocks  = DJ.EX()$blocks
sd_lev= .1
#kind of RNA seq
noisy_blocks=blocks+rnorm(1024, sd=sd_lev)
plot(noisy_blocks , pch=19)
lines(blocks ,   col="green")
bumps  = DJ.EX()$bumps
doppler  = DJ.EX()$doppler
plot(bumps)
noisy_bumps= bumps+rnorm(1024, sd=sd_lev)
noisy_doppler= doppler+rnorm(1024, sd=sd_lev)
#kind of ATACseq
plot(noisy_bumps , pch=19)
lines(bumps , col="green")
plot(noisy_doppler , pch=19)
lines(doppler , col="green")
fit_block <- fit_ash_hmm(
noisy_blocks,
rep(sd_lev, length(noisy_bumps)),
shared_mixture = FALSE,
verbose =FALSE,
maxiter = 10
)
fit_bumps <- fit_ash_hmm(
noisy_bumps,
rep(sd_lev, length(noisy_bumps)),
shared_mixture = FALSE,
verbose = TRUE
)
fit_doppler <- fit_ash_hmm(
noisy_doppler,
rep(sd_lev, length(noisy_bumps)),
shared_mixture = FALSE,
verbose = TRUE
)
plot(fit_bumps$posterior$mean, type='l')
lines(bumps, col="green", pch=19)
lines(10*fit_bumps$posterior$lfsr,col="red")
mean((fit_bumps$posterior$mean-bumps)^2)
plot(fit_block$posterior$mean, type='l')
lines(blocks, col="green" )
lines(5*fit_block$posterior$lfsr,col="red")
mean((fit_block$posterior$mean-blocks)^2)
plot(fit_doppler$posterior$mean , type='l')
lines( doppler, col="green" )
lines(5*fit_block$posterior$lfsr,col="red")
mean((fit_doppler$posterior$mean-doppler)^2)
lines(5*fit_doppler$posterior$lfsr,col="red")
plot(fit_doppler$posterior$mean , type='l')
lines( doppler, col="green" )
lines(5*fit_doppler$posterior$lfsr,col="red")
mean((fit_doppler$posterior$mean-doppler)^2)
