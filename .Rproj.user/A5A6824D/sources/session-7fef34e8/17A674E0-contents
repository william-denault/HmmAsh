    bty = "n"
  )
}
par(old_par)
```

# Fit HmmAsh

Each state learns its own adaptive-shrinkage mixture because
`shared_mixture = FALSE`. The strict null is a Dirac mass at zero. A full
transition topology is used so a block may jump directly between two nonzero
levels.

```{r fit-helper}
fit_signal <- function(y, se, nonnegative) {
  elapsed <- system.time({
    fit <- fit_ash_hmm(
      y = y,
      se = se,
      half_grid = params$half_grid,
      topology = "full",
      shared_mixture = FALSE,
      nonnegative_state_means = nonnegative,
      null_state = "pointmass",
      maxiter = params$maxiter,
      verbose = params$verbose
    )
  })[["elapsed"]]

  list(fit = fit, elapsed = unname(elapsed))
}
```

```{r fit-models, results='hide'}
one_sided <- lapply(names(observed), function(name) {
  fit_signal(
    observed[[name]],
    standard_error[[name]],
    nonnegative = TRUE
  )
})
names(one_sided) <- names(observed)

signed <- NULL
if (isTRUE(params$run_signed_comparison)) {
  signed <- lapply(names(observed), function(name) {
    fit_signal(
      observed[[name]],
      standard_error[[name]],
      nonnegative = FALSE
    )
  })
  names(signed) <- names(observed)
}
```

The calls above deliberately use `length(signal)` when constructing each
standard-error vector. All three Donoho-Johnstone examples currently have
length 1024, but relying on the length of a different signal is fragile.

# Numerical comparison

```{r fit-summary}
summarize_fit <- function(result, signal_name, model_name) {
  fit <- result$fit
  model_selection <- fit$model_selection %||% list()
  steps <- fit$step_selection %||% list()

  data.frame(
    signal = signal_name,
    model = model_name,
    effect_support = fit$fitted$effect_support,
    mse = mean((fit$posterior$mean - truth[[signal_name]])^2),
    elapsed_seconds = result$elapsed,
    retained_states = length(fit$fitted$mu),
    occupied_states = steps$occupied_state_count %||% NA_integer_,
    decoded_steps = steps$step_count %||% NA_integer_,
    collapsed_to_null = isTRUE(model_selection$collapsed_to_null),
    minimum_posterior_mean = min(fit$posterior$mean),
    log_likelihood = fit$log_likelihood,
    row.names = NULL
  )
}

summary_rows <- do.call(
  rbind,
  lapply(names(one_sided), function(name) {
    summarize_fit(one_sided[[name]], name, "one-sided")
  })
)

if (!is.null(signed)) {
  summary_rows <- rbind(
    summary_rows,
    do.call(
      rbind,
      lapply(names(signed), function(name) {
        summarize_fit(signed[[name]], name, "signed")
      })
    )
  )
}

summary_rows <- summary_rows[
  order(summary_rows$signal, summary_rows$model),
]
knitr::kable(summary_rows, digits = 4)
```

MSE is reported only because the benchmark truth is known. In real data, use
posterior uncertainty, fitted state occupancy, boundary probabilities, and
scientific interpretability rather than selecting a model from an unavailable
truth-based error.

# Posterior reconstructions

The upper panel of each figure compares the truth with posterior means. The
lower panel shows lfsr on its natural $[0,1]$ scale rather than multiplying it
by 5 or 10 and placing it on the effect axis.

In the one-sided model,

\[
\Pr(\beta_t\ge 0\mid Y)=1,
\qquad
\operatorname{lfsr}_t=\Pr(\beta_t=0\mid Y),
\]

so lfsr is best interpreted as a local exact-null probability. In signed mode
it has the usual false-sign interpretation.

```{r plotting-helper}
plot_reconstruction <- function(signal_name, result, model_name) {
  fit <- result$fit
  old_par <- par(no.readonly = TRUE)
  layout(matrix(1:2, ncol = 1), heights = c(2, 1))
  par(mar = c(3, 4, 2, 1))
  on.exit({
    layout(1)
    par(old_par)
  }, add = TRUE)

  plot(
    observed[[signal_name]],
    pch = 16,
    cex = 0.25,
    col = grDevices::adjustcolor("grey50", alpha.f = 0.35),
    xlab = "position",
    ylab = "effect",
    main = paste(signal_name, "-", model_name, "fit")
  )
  lines(truth[[signal_name]], col = "forestgreen", lwd = 2)
  lines(fit$posterior$mean, col = "navy", lwd = 1.7)
  abline(h = 0, col = "grey75", lty = 3)
  legend(
    "topright",
    legend = c("truth", "posterior mean"),
    col = c("forestgreen", "navy"),
    lty = 1,
    lwd = c(2, 1.7),
    bty = "n"
  )

  plot(
    fit$posterior$lfsr,
    type = "l",
    ylim = c(0, 1),
    col = "firebrick",
    xlab = "position",
    ylab = "lfsr",
    main = "Local uncertainty"
  )
  abline(h = c(0.05, 0.1), col = c("grey60", "grey75"), lty = c(2, 3))
}
```

